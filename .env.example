# ==========================================
# RIDERABBIT - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================

# ------------------------------------------
# BACKEND (.env inside /backend directory)
# ------------------------------------------
PORT=3000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/riderabbit_dev
DB_NAME=RIDERABIT

# Authentication (Generate strong random strings for these)
ACCESS_TOKEN_SECRET=your_super_secret_access_token_string
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_string
ACCESS_TOKEN_EXPIRES_IN=12h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CLIENT_URLS=http://localhost:5173,http://localhost:5174

# Cloudinary (Image Hosting)
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Service (Mailtrap for Dev, Resend for Prod)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_mailtrap_user
EMAIL_PASSWORD=your_mailtrap_password
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=onboarding@resend.dev
ADMIN_EMAIL=admin@yourdomain.com

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_secure_webhook_secret

# ------------------------------------------
# FRONTEND (.env inside /client directory)
# ------------------------------------------
VITE_API_URL=http://localhost:3000/api
VITE_RAZORPAY_KEY_ID=rzp_test_yourkeyid
VITE_FIREBASE_API_KEY=your_firebase_key
